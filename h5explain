#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  h5explain [-n|--non-strict] FILE [OFFSET]
  h5explain -h|--help

Arguments:
  FILE       HDF5 file to open with GNU poke
  OFFSET     Optional starting byte offset, decimal or hexadecimal (0x...)

Options:
  -h, --help           show this help
  -n, --non-strict     use non-strict poke mapping to keep exploring
EOF
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
non_strict=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -n|--non-strict)
            non_strict=1
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            printf 'h5explain: unknown option: %s\n\n' "$1" >&2
            usage >&2
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -lt 1 || $# -gt 2 ]]; then
    usage >&2
    exit 2
fi

file=$1
offset=${2:-}

if [[ ! -e "$file" ]]; then
    printf 'h5explain: file not found: %s\n' "$file" >&2
    exit 1
fi

if [[ "$file" == *$'\n'* ]]; then
    printf 'h5explain: file names containing newlines are not supported\n' >&2
    exit 1
fi

if [[ -n "$offset" && ! "$offset" =~ ^([0-9]+|0[xX][0-9A-Fa-f]+)$ ]]; then
    printf 'h5explain: OFFSET must be decimal or hexadecimal (0x...): %s\n' "$offset" >&2
    exit 2
fi

escape_poke_file_arg() {
    local value=$1
    local tab=$'\t'
    value=${value//\\/\\\\}
    value=${value//#/\\#}
    value=${value// /\\ }
    value=${value//"$tab"/\\"$tab"}
    printf '%s' "$value"
}

escape_poke_string() {
    local value=$1
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    printf '%s' "$value"
}

if [[ -n "${POKE_LOAD_PATH:-}" ]]; then
    export POKE_LOAD_PATH="$script_dir/pickles:$POKE_LOAD_PATH"
else
    export POKE_LOAD_PATH="$script_dir/pickles"
fi

cmd_file=$(mktemp "${TMPDIR:-/tmp}/h5explain.XXXXXX")
trap 'rm -f "$cmd_file"' EXIT

{
    printf '.file %s\n' "$(escape_poke_file_arg "$file")"
    printf '.set pretty-print yes\n'
    printf '.set omode tree\n'
    printf 'load h5explain\n'
    printf 'h5explain_non_strict = %d\n' "$non_strict"
    if [[ -n "$offset" ]]; then
        printf 'h5explain_start ("%s")\n' "$(escape_poke_string "$offset")"
    else
        printf 'h5explain_start\n'
    fi
} >"$cmd_file"

exec poke --quiet -s "$cmd_file"
